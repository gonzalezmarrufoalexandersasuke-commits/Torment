-- BUSCAR CRUCIFIJO EN MANO O EN INVENTARIO
local function buscarCrucifijo(personaje)
	if not personaje then return nil end
	for _, item in ipairs(personaje:GetChildren()) do
		if item:IsA("Tool") and (item.Name:lower():find("crucifix") or item.Name:lower():find("crucifijo")) then
			return item
		end
	end
	local backpack = localPlayer:FindFirstChild("Backpack")
	if backpack then
		for _, item in ipairs(backpack:GetChildren()) do
			if item:IsA("Tool") and (item.Name:lower():find("crucifix") or item.Name:lower():find("crucifijo")) then
				return item
			end
		end
	end
	return nil
end

-- EJECUTAR CINEMÁTICA DE CRUCIFICACIÓN (8 SEGUNDOS)
local function crucificarTorment(personaje, crucifijo)
	_G.B35_Shared.Crucificado = true
	crucifijo:Destroy()

	local sonidoCrucifijo = Instance.new("Sound")
	sonidoCrucifijo.SoundId = AUDIO_CRUCIFIJO
	sonidoCrucifijo.Volume = 4
	sonidoCrucifijo.Parent = entidad
	sonidoCrucifijo:Play()

	local aura = Instance.new("Highlight")
	aura.FillColor = Color3.fromRGB(170, 0, 255)
	aura.OutlineColor = Color3.fromRGB(255, 255, 255)
	aura.FillTransparency = 0.2
	aura.Parent = entidad

	local posSuelo = entidad.Position - Vector3.new(0, 3, 0)
	local raycastParametros = RaycastParams.new()
	raycastParametros.FilterType = Enum.RaycastFilterType.Exclude
	raycastParametros.FilterDescendantsInstances = {entidad, personaje}
	
	local resultadoRaycast = Workspace:Raycast(entidad.Position, Vector3.new(0, -20, 0), raycastParametros)
	if resultadoRaycast then
		posSuelo = resultadoRaycast.Position + Vector3.new(0, 0.05, 0)
	end

	local circuloSuelo = Instance.new("Part")
	circuloSuelo.Size = Vector3.new(12, 0.05, 12)
	circuloSuelo.Transparency = 1
	circuloSuelo.Anchored = true
	circuloSuelo.CanCollide = false
	circuloSuelo.CFrame = CFrame.new(posSuelo)
	circuloSuelo.Parent = Workspace

	local decalCirculoArriba = Instance.new("Decal")
	decalCirculoArriba.Texture = CIRCULO_SUELO_ID
	decalCirculoArriba.Face = Enum.NormalId.Top
	decalCirculoArriba.Parent = circuloSuelo

	local modeloCadenas = Instance.new("Model")
	modeloCadenas.Name = "CadenasTorment"
	modeloCadenas.Parent = Workspace

	local angulos = {45, 135, 225, 315}
	local listaCadenas = {}

	for _, angulo in ipairs(angulos) do
		local cadena = Instance.new("Part")
		cadena.Size = Vector3.new(2, 8, 0.05)
		cadena.Transparency = 1
		cadena.Anchored = true
		cadena.CanCollide = false
		
		local offsetSuelo = CFrame.new(posSuelo) * CFrame.Angles(0, math.rad(angulo), 0) * CFrame.new(0, 3, 4)
		cadena.CFrame = CFrame.lookAt(offsetSuelo.Position, entidad.Position) * CFrame.Angles(math.rad(-25), 0, 0)
		cadena.Parent = modeloCadenas

		local decalF = Instance.new("Decal")
		decalF.Texture = CADENA_ID; decalF.Face = Enum.NormalId.Front; decalF.Parent = cadena
		local decalB = Instance.new("Decal")
		decalB.Texture = CADENA_ID; decalB.Face = Enum.NormalId.Back; decalB.Parent = cadena

		table.insert(listaCadenas, cadena)
	end

	-- FASE 1: SUBE (3.5 SEC)
	local posArriba = entidad.CFrame * CFrame.new(0, 10, 0)
	local tweenSubir = TweenService:Create(
		entidad,
		TweenInfo.new(3.5, Enum.EasingStyle.Sine, Enum.EasingDirection.Out),
		{CFrame = posArriba}
	)
	tweenSubir:Play()
	task.wait(3.5)

	-- FASE 2: SE HUNDE EN LA TIERRA (4.5 SEC)
	local posTragado = CFrame.new(posSuelo - Vector3.new(0, 15, 0))
	local tweenBajar = TweenService:Create(
		entidad,
		TweenInfo.new(4.5, Enum.EasingStyle.Quad, Enum.EasingDirection.In),
		{CFrame = posTragado, Transparency = 1}
	)

	for _, cad in ipairs(listaCadenas) do
		TweenService:Create(
			cad,
			TweenInfo.new(4.5, Enum.EasingStyle.Quad, Enum.EasingDirection.In),
			{CFrame = cad.CFrame * CFrame.new(0, -15, 0), Transparency = 1}
		):Play()
	end

	tweenBajar:Play()
	tweenBajar.Completed:Wait()

	circuloSuelo:Destroy()
	modeloCadenas:Destroy()
	if entidad then entidad:Destroy() end

	mostrarLogro(ID_LOGRO_CRUCIFIJO)
end

-- DETECTAR JUGADOR AGACHADO
local function estaAgachado(personaje)
	if not personaje then return false end
	local hum = personaje:FindFirstChildOfClass("Humanoid")
	if hum then
		if hum.MoveDirection.Magnitude > 0 and hum.HipHeight < 1.2 then return true end
		if hum:GetAttribute("Crouching") == true or hum.HipHeight < 1.4 then return true end
	end
	if personaje:GetAttribute("Crouching") == true or localPlayer:GetAttribute("Crouching") == true then
		return true
	end
	return false
end

-- DETECCIÓN EXCLUSIVA PARA ESQUINAS (ÚNICA FORMA DE SOBREVIVIR)
local function estaProtegidoEnEsquina(personaje)
	if not personaje or not personaje:FindFirstChild("HumanoidRootPart") then return false end
	
	-- Debe estar agachado obligatoriamente
	if not estaAgachado(personaje) then return false end

	local pos = personaje.HumanoidRootPart.Position
	
	for _, sala in ipairs(currentRooms:GetChildren()) do
		local centroSala = sala:FindFirstChild("RoomStart") or sala:FindFirstChild("Floor") or sala:FindFirstChild("PrimaryPart")
		if centroSala and centroSala:IsA("BasePart") then
			local distCentro = (pos - centroSala.Position).Magnitude
			if distCentro < 45 then
				local tamanoPiso = centroSala.Size
				local posRelativa = centroSala.CFrame:PointToObjectSpace(pos)
				
				-- Límites estrictos para considerar esquina
				local limiteX = math.max((tamanoPiso.X / 2) - 3, 1)
				local limiteZ = math.max((tamanoPiso.Z / 2) - 3, 1)
				
				if math.abs(posRelativa.X) >= limiteX and math.abs(posRelativa.Z) >= limiteZ then
					return true
				end
			end
		end
	end

	return false
end

